   "source": [
    "import time\n",
    "import subprocess\n",
    "from IPython.display import clear_output\n",
    "\n",
    "# 2초마다 구글 서버의 GPU 상태를 새로고침해서 보여줍니다.\n",
    "while True:\n",
    "    clear_output(wait=True)\n",
    "    result = subprocess.run(['nvidia-smi'], capture_output=True, text=True)\n",
    "    print(result.stdout)\n",
    "    time.sleep(2)"
   ]
  }
